# Sanity CMS — create project at sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_write_token        # Settings > API > Tokens (Editor role)

# Supabase — create project at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe — create account at stripe.com
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Subscription price IDs (create in Stripe dashboard)
STRIPE_MONTHLY_PRICE_ID=price_xxx
STRIPE_ANNUAL_PRICE_ID=price_xxx

# Resend — create account at resend.com
RESEND_API_KEY=re_xxx
EMAIL_FROM=newsletter@highschoolsportselite.com

# App
NEXT_PUBLIC_SITE_URL=https://highschoolsportselite.com
CRON_SECRET=your_random_secret_string   # used to protect /api/cron routes
